{
  "name": "@coffeectx/indexer",
  "version": "0.1.0",
  "description": "CLI indexer — uses an LLM agent to read repos/logs/artifacts and populate the coffeectx knowledge graph",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "coffeectx-index": "./dist/index.js",
    "coffeectx-setup": "./dist/setup/index.js"
  },
  "files": [
    "dist",
    "skills",
    "prompts"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "postinstall": "node dist/setup/index.js",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "dependencies": {
    "@coffeectx/core": "^0.1.0",
    "@coffeectx/server": "^0.1.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@qwen-code/sdk": "file:../qwen-code/packages/sdk-typescript",
    "@types/node": "^20.14.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
