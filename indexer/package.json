{
  "name": "@coffeectx/indexer",
  "version": "0.1.5",
  "description": "CLI indexer — uses an LLM agent to read repos/logs/artifacts and populate the coffeectx knowledge graph",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "coffeectx": "./dist/index.js",
    "coffeectx-ui": "./dist/ui/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "webui-dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "bundle-webui": "node scripts/bundle-webui.mjs",
    "prepublishOnly": "npm run build && npm run bundle-webui",
    "ui": "node dist/ui/index.js"
  },
  "dependencies": {
    "@coffeectx/core": "^0.1.5",
    "@coffeectx/secrets-core": "^0.1.5",
    "@coffeectx/secrets-pi": "^0.1.5",
    "@coffeectx/server": "^0.1.5",
    "@coffeectx/tools": "^0.1.5",
    "@earendil-works/pi-ai": "^0.79.6",
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "chokidar": "^4.0.3",
    "cron-parser": "^5.5.0",
    "fastify": "^5.0.0",
    "typebox": "^1.1.38",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
