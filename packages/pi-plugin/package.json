{
  "name": "@coffeectx/pi-plugin",
  "version": "0.1.3",
  "description": "pi.dev extension that exposes the coffeectx knowledge graph as tools. Install + reference from ~/.pi/agent/extensions/.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coffeectx/core": "^0.1.3",
    "@coffeectx/tools": "^0.1.3",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
