{
  "name": "@coffeectx/secrets-mcp",
  "version": "0.1.7",
  "description": "MCP server exposing coffeectx secret-scoped command execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "coffeectx-secrets-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
